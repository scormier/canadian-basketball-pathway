---
---

<header
  class="w-full py-4 px-4 border-b border-gray-200 bg-white sticky top-0 z-50"
  role="banner"
>
  <nav
    class="max-w-7xl mx-auto flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="text-lg font-bold text-gray-900 hover:text-gray-700 transition-colors"
      aria-label="Canadian Basketball Pathway - Home"
    >
      <span class="text-blue-600">🏀</span> Canadian Basketball Pathway
    </a>

    <div class="flex items-center gap-4">
      <a
        href="/reference/glossary"
        id="glossary-nav-link"
        class="text-sm text-gray-600 hover:text-gray-900 transition-colors hidden sm:block"
      >
        Glossary
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  document.getElementById('glossary-nav-link')?.addEventListener('click', function() {
    window.posthog?.capture('glossary_nav_clicked', {
      location: 'header'
    });
  });
</script>
