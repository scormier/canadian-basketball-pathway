---
interface Props {
  type?: 'warning' | 'info' | 'tip';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  warning: {
    border: 'border-amber-400',
    bg: 'bg-amber-50',
    icon: '⚠️',
    titleColor: 'text-amber-800',
  },
  info: {
    border: 'border-blue-400',
    bg: 'bg-blue-50',
    icon: 'ℹ️',
    titleColor: 'text-blue-800',
  },
  tip: {
    border: 'border-green-400',
    bg: 'bg-green-50',
    icon: '💡',
    titleColor: 'text-green-800',
  },
};

const s = styles[type];
---

<div class:list={["not-prose my-6 rounded-md border-l-4 px-5 py-4", s.border, s.bg]}>
  {title && (
    <p class:list={["text-sm font-semibold mb-1", s.titleColor]}>
      <span class="mr-1">{s.icon}</span> {title}
    </p>
  )}
  <div class="text-sm text-gray-700 leading-relaxed [&>p]:mb-2 [&>p:last-child]:mb-0">
    <slot />
  </div>
</div>
