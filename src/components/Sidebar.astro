---
import { NAV_SECTIONS } from "../config/site.mjs";

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const FEEDBACK_URL = "https://tally.so/r/0Qvl2j";
const BMAC_URL = "https://www.buymeacoffee.com/scormier";
---

<aside class="hidden lg:block w-64 shrink-0">
  <nav class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-4 pb-8" aria-label="Guide navigation">
    {NAV_SECTIONS.map((section) => (
      <div class="mb-6">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2 px-3">
          {section.label}
        </h3>
        <ul class="space-y-0.5" role="list">
          {section.items.map((item) => {
            const isActive = currentPath === item.href || currentPath === item.href + '/';
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block px-3 py-1.5 rounded-md text-sm transition-colors sidebar-nav-link",
                    isActive
                      ? "bg-blue-50 text-blue-700 font-medium"
                      : "text-gray-600 hover:text-gray-900 hover:bg-gray-50",
                  ]}
                  aria-current={isActive ? "page" : undefined}
                  data-href={item.href}
                  data-label={item.label}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    <div class="mt-4 px-3 space-y-2">
      <a
        href={FEEDBACK_URL}
        target="_blank"
        rel="noopener noreferrer"
        id="sidebar-feedback-link"
        class="flex items-center justify-center gap-1.5 w-full px-3 py-2 text-xs text-blue-700 bg-blue-50 border border-blue-200 rounded hover:bg-blue-100 transition-colors no-underline"
      >
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <span>Share feedback</span>
        <span>→</span>
      </a>
      <a
        href={BMAC_URL}
        target="_blank"
        rel="noopener noreferrer"
        id="buy-me-coffee-link"
        class="flex items-center justify-center gap-1.5 w-full px-3 py-2 text-xs text-yellow-700 bg-yellow-50 border border-yellow-200 rounded hover:bg-yellow-100 transition-colors no-underline"
      >
        <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.185-1.756.204-.567.019-1.134.01-1.7-.015-.746-.034-1.494-.076-2.232-.18-.451-.063-.842-.193-1.105-.568-.2-.286-.24-.65-.278-1.002l-1.038-9.917-.068-.66a.478.478 0 01.534-.53h0c.185.015.37.034.556.053a38.31 38.31 0 005.576.213c.075 0 .15-.002.225-.004l.078-.001a38.393 38.393 0 005.199-.57h0z" />
        </svg>
        <span>Buy us a coffee</span>
        <span>→</span>
      </a>
    </div>
  </nav>
</aside>

<script is:inline>
  document.querySelectorAll('.sidebar-nav-link').forEach(function(link) {
    link.addEventListener('click', function() {
      window.posthog?.capture('guide_navigation_clicked', {
        destination: link.getAttribute('data-href'),
        label: link.getAttribute('data-label'),
        location: 'sidebar'
      });
    });
  });

  document.getElementById('sidebar-feedback-link')?.addEventListener('click', function() {
    window.posthog?.capture('sidebar_feedback_clicked', {
      location: 'sidebar'
    });
  });

  document.getElementById('buy-me-coffee-link')?.addEventListener('click', function() {
    window.posthog?.capture('buy_me_coffee_clicked', {
      location: 'sidebar'
    });
  });
</script>
