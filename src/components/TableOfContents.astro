---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <div class="hidden xl:block w-56 shrink-0">
    <nav class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pl-4 border-l border-gray-200" aria-label="Table of contents">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">
        On this page
      </h3>
      <ul class="space-y-1.5" role="list">
        {filteredHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                "block text-sm text-gray-500 hover:text-gray-900 transition-colors",
                heading.depth === 3 && "pl-3",
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}
